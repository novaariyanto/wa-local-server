{
  "name": "wa-server-local",
  "version": "1.0.0",
  "description": "WhatsApp Web Engine for Local Server",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Antigravity",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "check-internet-connected": "^2.0.0",
    "electron-log": "^5.0.0",
    "electron-store": "^8.1.0",
    "os-utils": "^0.0.14",
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.waserver.local",
    "productName": "WA Server Local",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ]
  }
}
